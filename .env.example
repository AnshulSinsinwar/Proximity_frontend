# =============================================
# Proximity Frontend — Environment Variables
# =============================================
# Copy this file to .env for local development.
# Set these as environment variables on Vercel.

# Backend API URL — MUST include /api/v1 at the end
# Local:      http://localhost:3000/api/v1
# Production: https://your-backend.koyeb.app/api/v1
VITE_API_URL=https://your-backend.koyeb.app/api/v1

# Socket.IO URL — NO /api/v1 at the end
# Local:      http://localhost:3000
# Production: https://your-backend.koyeb.app
VITE_SOCKET_URL=https://your-backend.koyeb.app
